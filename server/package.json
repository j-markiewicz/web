{
	"name": "transit-map-server",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "npm run build && node build/src/main.js",
		"build": "tsc",
		"migrate": "npx sequelize-cli db:migrate",
		"unmigrate": "npx sequelize-cli db:migrate:undo",
		"seed": "npx sequelize-cli db:seed:all",
		"unseed": "npx sequelize-cli db:seed:undo:all"
	},
	"dependencies": {
		"argon2": "^0.41.1",
		"compression": "^1.7.4",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"csv": "^6.3.10",
		"dotenv": "^16.4.5",
		"express": "^4.21.1",
		"gtfs-realtime-bindings": "^1.1.1",
		"jsonwebtoken": "^9.0.3",
		"ms": "^2.1.3",
		"pg": "^8.21.0",
		"pg-hstore": "^2.3.4",
		"sequelize": "^6.37.8",
		"sqlite3": "^6.0.1",
		"superstruct": "^2.0.2",
		"temporal-polyfill": "^0.2.5",
		"yauzl-promise": "^4.0.0"
	},
	"devDependencies": {
		"@types/compression": "^1.7.5",
		"@types/cookie-parser": "^1.4.7",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/geojson": "^7946.0.14",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/ms": "^2.1.0",
		"@types/node": "^22.7.6",
		"@types/yauzl-promise": "^4.0.1",
		"sequelize-cli": "^6.6.5",
		"typescript": "^5.6.3"
	}
}
